# ENGINE 1: Log Collector Configuration
# Real-time log collection with LLM analysis

# Downstream Engines
ENGINE3_URL=http://xgboost-classifier:8000
ENGINE4_URL=http://decision-engine:8004

# OpenAI (Optional - for LLM log analysis)
OPENAI_API_KEY=your_openai_api_key_here

# Control Taxonomy
CONTROL_TAXONOMY_PATH=/app/data/control_taxonomy_validated.json

# Server
HOST=0.0.0.0
PORT=8001

# MCP Server (Read-only command execution)
ENABLE_MCP=true
MCP_TIMEOUT=30

# Logging
LOG_LEVEL=INFO
