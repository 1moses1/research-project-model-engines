# ENGINE 7: Authentication Engine
# Rwanda NCSA Compliance Auditor

# JWT Configuration
AUTH_SECRET_KEY=your-super-secret-key-change-in-production
AUTH_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Service Configuration
AUTH_PORT=8007
AUTH_HOST=0.0.0.0

# Audit User Configuration
AUDIT_USERNAME=rwanda_ncsa_auditor
AUDIT_SHELL=/bin/rbash
AUDIT_SESSION_TIMEOUT_MINUTES=30

# Default Audit Directories (comma-separated)
AUDIT_DIRECTORIES=/var/log/,/var/log/audit/,/var/log/syslog,/var/log/auth.log

# SSH Configuration (for remote machine authentication)
SSH_TIMEOUT=30
SSH_KEY_PATH=/app/keys/

# Security Settings
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# Logging
LOG_LEVEL=INFO
LOG_FILE=/app/logs/auth.log
