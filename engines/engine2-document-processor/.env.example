# ENGINE 2: Document Processor Configuration
# LLM-powered document processing and control extraction

# OpenAI Configuration (Required for LLM features)
OPENAI_API_KEY=your_openai_api_key_here

# Control Taxonomy
CONTROL_TAXONOMY_PATH=/app/data/control_taxonomy_validated.json

# Server Configuration
HOST=0.0.0.0
PORT=8002

# File Upload Limits
MAX_FILE_SIZE_MB=50
BATCH_SIZE_LIMIT=10

# Semantic Matching
EMBEDDINGS_MODEL=all-MiniLM-L6-v2
EMBEDDINGS_CACHE=/app/data/embeddings

# Processing
TIMEOUT_SECONDS=300
RETRY_ATTEMPTS=3

# Logging
LOG_LEVEL=INFO
