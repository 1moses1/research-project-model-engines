# ENGINE 3: XGBoost Compliance Classifier Configuration
# Rwanda NCSA Compliance Auditor

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Model Configuration (paths are relative to container)
MODEL_PATH=/app/models/rwanda_ncsa_compliance_auditor.json
LABEL_ENCODER_PATH=/app/models/label_encoder.pkl
TFIDF_VECTORIZER_PATH=/app/models/tfidf_vectorizer.pkl
DAY_ENCODER_PATH=/app/models/day_encoder.pkl
FEATURES_PATH=/app/models/features.json

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Performance
WORKERS=4
MAX_BATCH_SIZE=1000

# Monitoring (optional)
ENABLE_METRICS=true
METRICS_PORT=9090
